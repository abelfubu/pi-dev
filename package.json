{
	"name": "@abelfubu/pi-dev",
	"version": "0.1.0",
	"description": "Pi extension with Jira, GitHub, and code-check tools and skills",
	"keywords": [
		"pi-package",
		"jira",
		"atlassian",
		"pi-extension"
	],
	"license": "MIT",
	"files": [
		"extensions",
		"lib",
		"prompts",
		"skills",
		"themes",
		"README.md",
		"CONTEXT.md",
		"docs"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"pi": {
		"extensions": [
			"extensions",
			"!extensions/*.test.ts"
		],
		"skills": [
			"skills"
		],
		"themes": [
			"themes"
		],
		"prompts": [
			"prompts"
		]
	},
	"dependencies": {
		"extended-markdown-adf-parser": "^2.4.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "^0.80.2",
		"jiti": "^2.0.0",
		"typebox": "^1.3.0",
		"typescript": "^5.6.0",
		"vitest": "^3.2.6"
	},
	"engines": {
		"node": ">=20"
	}
}
